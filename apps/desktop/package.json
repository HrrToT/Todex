{
  "name": "@todex/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/main/index.js",
  "scripts": {
    "test": "vitest run",
    "dev": "vite --config vite.renderer.config.ts",
    "build": "tsc -p tsconfig.build.json && vite build --config vite.renderer.config.ts",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3,keytar",
    "smoke": "pnpm build && electron ./dist/main/smoke.js",
    "smoke:electron": "pnpm run rebuild:native && pnpm run smoke"
  },
  "dependencies": {
    "@todex/contracts": "workspace:*",
    "better-sqlite3": "^12.2.0",
    "electron": "^36.5.0",
    "keytar": "^7.9.0",
    "lucide-react": "0.468.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.0.1",
    "@testing-library/user-event": "14.5.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "jsdom": "25.0.1"
  }
}
